# Environment variables for local development
# Copy this file to .env.local and fill in your actual values

# === Agora RTC (Real-Time Communication) ===
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# === Agora Whiteboard Credentials ===
AGORA_WHITEBOARD_APP_ID=your_agora_whiteboard_app_id
AGORA_WHITEBOARD_AK=your_agora_whiteboard_access_key
AGORA_WHITEBOARD_SK=your_agora_whiteboard_secret_key

# === Netless Whiteboard (Alternative to Agora Whiteboard) ===
# NETLESS_SDK_TOKEN=your_netless_sdk_token
# NETLESS_APP_ID=your_netless_app_id
# NETLESS_REGION=sg
# NETLESS_API_BASE=https://api.netless.link

# === Feature Flags ===
NEXT_PUBLIC_USE_AGORA_WHITEBOARD=true

# === AWS Configuration ===
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_session_token

# === AWS S3 Configuration ===
AWS_S3_BUCKET_NAME=jvtutorcorner-uploads
# USE_S3_REDIRECT=false

# === DynamoDB Tables ===
DYNAMODB_TABLE_CAROUSEL=jvtutorcorner-carousel
DYNAMODB_TABLE_ORDERS=jvtutorcorner-orders
DYNAMODB_TABLE_PROFILES=jvtutorcorner-profiles
DYNAMODB_TABLE_ROLES=jvtutorcorner-roles
DYNAMODB_TABLE_PAGE_PERMISSIONS=jvtutorcorner-page-permissions
DYNAMODB_TABLE_PLAN_UPGRADES=jvtutorcorner-plan-upgrades
DYNAMODB_TABLE_USER_POINTS=jvtutorcorner-user-points
DYNAMODB_TABLE_POINTS_ESCROW=jvtutorcorner-points-escrow
WHITEBOARD_TABLE=jvtutorcorner-whiteboard
DYNAMODB_TABLE_COURSES=jvtutorcorner-courses
DYNAMODB_TABLE_APP_PERMISSIONS=jvtutorcorner-app-permissions
DYNAMODB_TABLE_AI_MODELS=jvtutorcorner-ai-models
# 關鍵業務日誌表（精簡版，供 AI 查詢，自動 TTL 30 天）
DYNAMODB_TABLE_KEY_LOGS=jvtutorcorner-key-logs
# KEY_LOG_TTL_DAYS=30  # 可選，覆蓋預設保留天數

# === Profiles Service Configuration ===
# PROFILES_TABLE=jvtutorcorner-profiles
# PROFILES_LAMBDA_NAME=your_lambda_function_name
# PROFILES_FUNCTION_NAME=your_lambda_function_name
# PROFILES_API_URL=your_api_url
# PROFILES_ENDPOINT=your_api_endpoint

# === CI/CD AWS Configuration (Alternative credentials for CI environment) ===
# These are used as fallback if main AWS credentials are not set
# CI_AWS_REGION=ap-northeast-1
# CI_AWS_ACCESS_KEY_ID=your_ci_aws_access_key
# CI_AWS_SECRET_ACCESS_KEY=your_ci_aws_secret_key
# CI_AWS_SESSION_TOKEN=your_ci_session_token
# CI_AWS_S3_BUCKET_NAME=your_ci_s3_bucket

# === Google Analytics ===
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === Application Configuration ===
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# LOCAL_DATA_DIR=/path/to/local/data

# === Captcha Configuration ===
# CAPTCHA_SECRET=your_captcha_secret_key

# === Test Credentials (Auto-login Bypass) ===
# Admin
ADMIN_EMAIL=admin@jvtutorcorner.com
ADMIN_PASSWORD=123456
TEST_TEACHER_EMAIL=lin@test.com
TEST_TEACHER_PASSWORD=123456
TEST_STUDENT_EMAIL=basic@test.com
TEST_STUDENT_PASSWORD=123456
LOGIN_BYPASS_SECRET=jv_secret_bypass_2024

# === Node Environment ===
# NODE_ENV=development

# === AI Services ===
GEMINI_API_KEY=your_gemini_api_key

# === Server-side Auth ===
# HMAC-SHA256 secret for session signing (Required for secure state management)
SESSION_SECRET=your_session_secret_change_in_production
# HMAC-SHA256 secret for server-to-server API calls
API_HMAC_SECRET=your_api_hmac_secret_change_in_production
# DynamoDB table for session storage
DYNAMODB_TABLE_SESSIONS=jvtutorcorner-sessions