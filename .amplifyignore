# Amplify Deployment - Exclude unnecessary build artifacts and large dependencies 
# This file tells Amplify CLI which files NOT to upload during deployment

# Exclude development build artifacts from .next (~1.6GB saved)
# The .next/dev folder contains source maps and build cache for development only
.next/dev/**
.next/cache/**
.next/trace
.next/.test-build
.next/static/**/*.map
.next/static/**/*.test.*

# Development dependencies
node_modules/.bin/**
node_modules/**/.git/**
node_modules/**/CHANGELOG*
node_modules/**/README*
node_modules/**/LICENSE*
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/example/**
node_modules/**/examples/**
node_modules/**/*.md
node_modules/**/*.ts
node_modules/**/.eslintignore
node_modules/**/.eslintrc*
node_modules/**/tsconfig.json
node_modules/**/.prettierrc*
node_modules/**/.editorconfigignore

# Testing and development
coverage/
.vscode/
.idea/
dist/
build/ 
tmp/
*.log

# Python/Virtual environment
.venv/
__pycache__/
*.pyc

# Environment variables (keep only production)
.env.local
.env.development

# Git
.git/
.github/

# IDE and OS files
.DS_Store
.editorconfig
*.pem
.gitignore
.npmrc

# Test related
playwright-report/
test-results/
e2e/
.auth/

# Documentation and misc
*.md
docs/
DEPLOYMENT_GUIDE.md
README*.md
architecture_overview.md
*.jpg
*.png

# Source maps (optional - disable if you need debugging)
**/*.map

# API test scripts
test_client.py
test_vision.py
testToken.js
main.py
test-course-alignment-debug.js
