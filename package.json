{
  "name": "jvtutorcorner-rwd",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:http": "next dev -p 3001",
    "dev:https": "next dev --experimental-https",
    "dev:proxy": "node dev-https-proxy.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup-agora": "node scripts/setup-agora-credentials.js",
    "setup-s3": "node scripts/setup-s3-storage.js",
    "skills:validate": "node scripts/validate-skill-frontmatter.js",
    "skills:update": "node scripts/update-skill-status.js",
    "test": "playwright test",
    "test:verify-skills": "playwright test --grep 'verification' && npm run skills:update",
    "test:verify-skills:ci": "playwright test --grep 'verification' --reporter=html",
    "test:production:stress": "NEXT_PUBLIC_BASE_URL=https://www.jvtutorcorner.com npx playwright test e2e/classroom_room_whiteboard_sync.spec.ts -g 'Stress test' --project=chromium",
    "test:production:stress:verbose": "NEXT_PUBLIC_BASE_URL=https://www.jvtutorcorner.com npx playwright test e2e/classroom_room_whiteboard_sync.spec.ts -g 'Stress test' --project=chromium --reporter=verbose",
    "test:production:load": "k6 run -e BASE_URL=https://www.jvtutorcorner.com .agents/skills/classroom-room-whiteboard-sync/scripts/production_load_test.js",
    "test:production:load:stress": "k6 run -e BASE_URL=https://www.jvtutorcorner.com -e TEST_TYPE=stress -e VUSER=20 .agents/skills/classroom-room-whiteboard-sync/scripts/production_load_test.js",
    "test:production:load:spike": "k6 run -e BASE_URL=https://www.jvtutorcorner.com -e TEST_TYPE=spike -e VUSER=10 .agents/skills/classroom-room-whiteboard-sync/scripts/production_load_test.js"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.13.1",
    "@aws-sdk/client-dynamodb": "^3.940.0",
    "@aws-sdk/client-lambda": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.956.0",
    "@aws-sdk/client-ssm": "^3.955.0",
    "@aws-sdk/lib-dynamodb": "^3.940.0",
    "@aws-sdk/lib-storage": "^3.956.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@qdrant/js-client-rest": "^1.17.0",
    "@xyflow/react": "^12.10.2",
    "agora-access-token": "^2.0.4",
    "agora-rtc-sdk-ng": "^4.23.0",
    "agora-rtm-sdk": "^2.2.3-1",
    "apache-arrow": "^21.1.0",
    "aws-amplify": "^6.15.8",
    "date-fns": "^4.1.0",
    "driver.js": "^1.4.0",
    "isolated-vm": "^6.0.2",
    "jspdf": "^4.0.0",
    "konva": "^9.3.18",
    "localforage": "^1.10.0",
    "netless-token": "^1.0.2",
    "next": "^16.0.10",
    "nodemailer": "^8.0.1",
    "pdfjs-dist": "^5.4.449",
    "protobufjs": "^8.0.0",
    "query-string": "^9.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.1.6",
    "reactflow": "^11.11.4",
    "stripe": "^20.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash": "^4.17.23",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.9.19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "fs": "^0.0.1-security",
    "http-proxy": "^1.18.1",
    "path": "^0.12.7",
    "playwright": "^1.57.0",
    "selfsigned": "^5.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
